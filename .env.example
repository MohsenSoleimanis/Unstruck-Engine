# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Models ===
MAS_ORCHESTRATOR_MODEL=claude-sonnet-4-20250514
MAS_WORKER_MODEL=gpt-4o-mini
MAS_VISION_MODEL=gpt-4o
MAS_EMBEDDING_MODEL=text-embedding-3-small

# === Memory ===
CHROMA_PERSIST_DIR=./data/chroma
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === LLMOps ===
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
MAS_ENABLE_TRACING=true
MAS_ENABLE_COST_TRACKING=true

# === API Server ===
MAS_HOST=0.0.0.0
MAS_PORT=8000
MAS_WORKERS=4

# === MCP ===
MCP_SERVER_URL=http://localhost:3000
